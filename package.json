{
  "name": "@avensio/pw-strength",
  "description": "Password Strength Checker using HTML 5 Attributes and the Validation API",
  "version": "0.2.4",
  "author": "Armin Kunkel",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vite build -c vite.lib.config.js",
    "preview": "vite preview"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "vue",
    "password",
    "strength"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@git.avensio.de:armin/pw-strength.git"
  },
  "bugs": {
    "url": "https://git.avensio.de/armin/pw-strength/-/issues"
  },
  "homepage": "https://git.avensio.de/armin/pw-strength#readme",
  "main": "./dist/password-strength.umd.js",
  "module": "./dist/password-strength.es.js",
  "types": "./dist/PasswordStrength.vue.d.ts",
  "exports": {
    "./style.css": "./dist/style.css",
    ".": {
      "import": "./dist/password-strength.es.js",
      "require": "./dist/password-strength.umd.js"
    }
  },
  "publishConfig": {
    "registry": "https://repo.avensio.de/repository/npm-registry/"
  },
  "devDependencies": {
    "@babel/types": "^7.17.0",
    "@intlify/vite-plugin-vue-i18n": "^3.4.0",
    "@vitejs/plugin-vue": "^2.3.1",
    "typescript": "^4.6.3",
    "vite": "^2.9.5",
    "vite-plugin-dts": "^1.1.0",
    "vue": "^3.2.33",
    "vue-i18n": "^9.1.9"
  }
}
